ent","tagName":"code","properties":{"className":["language-text"]},"children":[{"type":"text","value":"resolutions"}]},{"type":"text","value":" for multiple versions if necessary."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Remove choerodon-ui version declarations from the yarn.lock file."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Delete the .cache folder in node_modules (also delete .cache under sub-services if necessary)."}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Reinstall packages and run the project.\nThe version check flowchart is as follows:"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"img","properties":{"src":"https://hsop-image-host.su.bcebos.com/team/3/HSOP-BAIDU/5929798ac5e741299245c466d3ad6d38@依赖版本检查.png","alt":"Dependency Version Check.png"},"children":[]},{"type":"text","value":"\n"},{"type":"element","tagName":"hr","properties":{},"children":[]},{"type":"text","value":"\n"},{"type":"element","tagName":"h1","properties":{"id":"version-testing-verification-of-new-version-features-or-issues","style":"position:relative;"},"children":[{"type":"element","tagName":"a","properties":{"href":"#version-testing-verification-of-new-version-features-or-issues","ariaLabel":"version testing verification of new version features or issues permalink","className":["anchor","before"]},"children":[{"type":"element","tagName":"svg","properties":{"ariaHidden":"true","focusable":"false","height":"16","version":"1.1","viewBox":"0 0 16 16","width":"16"},"children":[{"type":"element","tagName":"path","properties":{"fillRule":"evenodd","d":"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09